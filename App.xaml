<Application x:Class="FPSOptimizer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FPSOptimizer.Converters"
             StartupUri="UI/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="UI/Themes.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converter -->
            <conv:CharacterSpacingConverter x:Key="CharSpacing"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
