<Page x:Class="FPSOptimizer.UI.Pages.PageDone"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="Finalizat">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="36,32,36,24">

            <!-- Success hero -->
            <Border Background="#061A0C" BorderBrush="#0D4020" BorderThickness="1"
                    CornerRadius="12" Padding="32,28" Margin="0,0,0,28">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="✅" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtDoneTitle" Text="Optimizare Finalizata!" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtDoneSubtitle"
                               Text="PC-ul tau este acum configurat pentru performanta maxima la gaming."
                               FontSize="13" Foreground="{StaticResource LGrayBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Next steps -->
            <TextBlock x:Name="TxtNextSteps" Text="📋  CE URMEAZĂ" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="#3C1A00" CornerRadius="4" Padding="6,2" Margin="0,0,10,0">
                            <TextBlock x:Name="TxtStep1Badge" Text="  1  " FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource OrangeBrush}"/>
                        </Border>
                        <TextBlock x:Name="TxtStep1Title" Text="Reporneste PC-ul" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource WhiteBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtStep1Desc"
                               Text="OBLIGATORIU pentru a aplica modificarile din registri, servicii si plan de energie. Efectul complet apare dupa restart."
                               FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TxtGpuTitle" Text="🎮  Setari GPU Manuale (Important!)" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,6"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                            <TextBlock x:Name="TxtGpuNvidia" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,4,0"/>
                            <TextBlock x:Name="TxtGpuNvidiaDesc" FontSize="11"
                                       Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                            <TextBlock x:Name="TxtGpuAmd" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource RedBrush}" Margin="0,0,4,0"/>
                            <TextBlock x:Name="TxtGpuAmdDesc" FontSize="11"
                                       Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TxtOverlayTitle" Text="🔕  Dezactiveaza Overlay-urile" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtOverlayDesc"
                               Text="Discord (Ctrl+Shift+I), Steam (Settings → In-Game), GeForce Experience (Alt+Z → Settings → General), Xbox Game Bar (Win+G → Settings). Fiecare overlay activ reduce FPS cu 2-8%."
                               FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TxtMonitorTitle" Text="📊  Monitorizare Performanta" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtMonitorDesc"
                               Text="Instaleaza MSI Afterburner + RivaTuner Statistics Server (gratuit) pentru overlay FPS, temperatura GPU/CPU si utilizare in timp real in jocuri."
                               FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TxtRestoreTitle" Text="🛡️  Restaurare" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtRestoreDesc"
                               Text="Backup-ul si Restore Point-ul sunt pe Desktop. Daca ceva nu functioneaza: Win+S → 'Create a restore point' → System Restore → alege punctul FPSOptimizer."
                               FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="TxtMaintTitle" Text="🌡️  Mentinere Performanta" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtMaint1" FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap" Margin="0,1,0,1"/>
                    <TextBlock x:Name="TxtMaint2" FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap" Margin="0,1,0,1"/>
                    <TextBlock x:Name="TxtMaint3" FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap" Margin="0,1,0,1"/>
                    <TextBlock x:Name="TxtMaint4" FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap" Margin="0,1,0,1"/>
                </StackPanel>
            </Border>

            <!-- Restart button -->
            <Button x:Name="BtnRestart" Content="🔄   Restart PC Acum"
                    Style="{StaticResource DangerButton}"
                    Width="260" Height="44" HorizontalAlignment="Center"
                    FontSize="14" Click="BtnRestart_Click"/>

        </StackPanel>
    </ScrollViewer>
</Page>
