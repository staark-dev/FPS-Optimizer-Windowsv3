<Page x:Class="FPSOptimizer.UI.Pages.PageBackup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="Protectie">
    <Grid Margin="36,24,36,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtTitle" Text="Protecție Sistem" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource WhiteBrush}"/>
            <TextBlock x:Name="TxtDesc" Text="Creeaza backup complet inainte de orice modificare. Poti reveni oricand."
                       FontSize="12" Foreground="{StaticResource LGrayBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Option 1: Restore Point -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkRestorePoint" Grid.Column="0"
                          Style="{StaticResource ModernCheckBox}"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" Text="🪟" FontSize="24"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock x:Name="TxtRPTitle" Text="Windows System Restore Point" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource WhiteBrush}" Margin="0,0,10,0"/>
                        <Border Background="#0D2A0D" BorderBrush="#1A6B1A" BorderThickness="1"
                                CornerRadius="3" Padding="6,1">
                            <TextBlock x:Name="TxtRPBadge" Text="✓  Recomandat" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource GreenBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TxtRPDesc"
                               Text="Creeaza un punct de restaurare nativ Windows. Poti reveni complet din System Restore (Win+S → 'Create a restore point')."
                               FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                    <TextBlock x:Name="RestorePointStatus" FontSize="10" Foreground="{StaticResource GrayBrush}"
                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Button x:Name="BtnCreateRestore" Grid.Column="3" Content="Creează Acum"
                        Style="{StaticResource GhostButton}" Padding="10,6" FontSize="11"
                        Click="BtnCreateRestore_Click" Margin="12,0,12,0" VerticalAlignment="Center"/>
                <Border x:Name="RestorePointResult" Grid.Column="4" Background="#0A200A" BorderBrush="#1A6B1A"
                        BorderThickness="1" CornerRadius="3" Padding="8,3" VerticalAlignment="Center"
                        Visibility="Collapsed">
                    <TextBlock x:Name="RestorePointResultText" Text="✓  Creat" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Option 2: Registry Backup -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkRegBackup" Grid.Column="0"
                          Style="{StaticResource ModernCheckBox}"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" Text="📋" FontSize="24"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtRegTitle" Text="Backup Registri Windows (.REG)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,3"/>
                    <TextBlock x:Name="TxtRegDesc"
                               Text="Exporta cheile de registri care vor fi modificate. Fisierele .REG sunt salvate pe Desktop si pot fi importate manual oricand cu dublu-click."
                               FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="3" Background="#0A1F0A" BorderBrush="#1A6B1A" BorderThickness="1"
                        CornerRadius="3" Padding="8,3" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock x:Name="TxtRegRisk" Text="Risc: Scazut" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Option 3: Services backup -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkSvcBackup" Grid.Column="0"
                          Style="{StaticResource ModernCheckBox}"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" Text="⚙️" FontSize="24"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtSvcTitle" Text="Backup Lista Servicii Windows (.CSV)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource WhiteBrush}" Margin="0,0,0,3"/>
                    <TextBlock x:Name="TxtSvcDesc"
                               Text="Salveaza starea curenta a tuturor serviciilor intr-un CSV. Util daca vrei sa re-activezi manual un serviciu mai tarziu."
                               FontSize="11" Foreground="{StaticResource LGrayBrush}" TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="3" Background="#0A1F0A" BorderBrush="#1A6B1A" BorderThickness="1"
                        CornerRadius="3" Padding="8,3" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock x:Name="TxtSvcRisk" Text="Risc: Scazut" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Warning if nothing selected -->
        <Border Grid.Row="4" x:Name="WarnBox" Background="#3C2800" BorderBrush="#6E4800"
                BorderThickness="1" CornerRadius="8" Padding="16,12"
                Visibility="Collapsed" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock x:Name="TxtWarnTitle" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource YellowBrush}" Margin="0,0,0,2"/>
                <TextBlock x:Name="TxtWarnMsg" FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource YellowBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" x:Name="OkBox" Background="#0A200A" BorderBrush="#1A5A1A"
                BorderThickness="1" CornerRadius="8" Padding="16,12"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock x:Name="TxtOkTitle" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource GreenBrush}" Margin="0,0,0,2"/>
                <TextBlock x:Name="TxtOkMsg" FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource GreenBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
