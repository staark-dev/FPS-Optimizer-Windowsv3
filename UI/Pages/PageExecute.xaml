<Page x:Class="FPSOptimizer.UI.Pages.PageExecute"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="Executie">
    <Grid Margin="36,24,36,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TxtTitle" Text="Execuție Optimizare" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource WhiteBrush}"/>
            <TextBlock x:Name="TxtDesc" Text="Nu inchide fereastra in timpul optimizarii."
                       FontSize="12" Foreground="{StaticResource LGrayBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Status + progress -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="16,14">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock x:Name="StatusIcon" Text="⏳" FontSize="16" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Pregatire..."
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource WhiteBrush}"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
                <ProgressBar x:Name="MainProgress"
                             Style="{StaticResource ModernProgressBar}"
                             Minimum="0" Maximum="100" Value="0" Height="8"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock x:Name="PctLabel" Text="0%" FontSize="10"
                               Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                    <TextBlock x:Name="TimeLabel" Text="" FontSize="10"
                               Foreground="{StaticResource GrayBrush}" Margin="12,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Module progress chips -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" Margin="0,0,0,12">
            <WrapPanel x:Name="ChipsPanel" Orientation="Horizontal"/>
        </ScrollViewer>

        <!-- Log -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0A0C1A" Padding="14,8"
                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding Source='LOG LIVE', Converter={StaticResource CharSpacing}, ConverterParameter=150}" />
                        <Border x:Name="LiveDot" Width="8" Height="8" CornerRadius="4"
                                Background="{StaticResource GreenBrush}" Margin="10,0,0,0"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <ScrollViewer Grid.Row="1" x:Name="LogScroll"
                              VerticalScrollBarVisibility="Auto" Background="#06080F">
                    <RichTextBox x:Name="LogBox" Background="Transparent"
                                 Foreground="{StaticResource WhiteBrush}"
                                 FontFamily="Cascadia Code, Consolas" FontSize="11.5"
                                 IsReadOnly="True" BorderThickness="0"
                                 Padding="14,10" IsDocumentEnabled="True"
                                 VerticalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
