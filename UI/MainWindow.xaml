<Window x:Class="FPSOptimizer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows FPS Optimizer Pro v3.0"
        Height="720" Width="1060"
        MinHeight="720" MinWidth="1060"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource WhiteBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Assets/AppIcon.png">

    <Window.Resources>
        <!-- Step indicator style -->
        <Style x:Key="StepItem" TargetType="Border">
            <Setter Property="Background" Value="#0D0F1E"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SIDEBAR -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#0D0F1E"
                BorderBrush="#232850" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Background="#080A14"
                        BorderBrush="#232850" BorderThickness="0,0,0,1"
                        Padding="0,22,0,18">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="32" HorizontalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,2"
                                   Text="{Binding Source='FPS OPTIMIZER', Converter={StaticResource CharSpacing}, ConverterParameter=150}" />
                        <TextBlock Text="Pro v3.0" FontSize="10"
                                   Foreground="{StaticResource GrayBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Step List -->
                <ItemsControl DockPanel.Dock="Top" x:Name="StepList" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StepItem}" x:Name="stepBorder"
                                    BorderBrush="#1A1D35" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Step number circle -->
                                    <Border Width="34" Height="34" CornerRadius="17"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding CircleBg}"
                                            BorderBrush="{Binding CircleBorder}" BorderThickness="1.5">
                                        <TextBlock Text="{Binding Number}" FontSize="14" FontWeight="Bold"
                                                   Foreground="{Binding NumberColor}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Labels -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding TitleColor}"/>
                                        <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                                   Foreground="{StaticResource GrayBrush}" Margin="0,1,0,0"/>
                                    </StackPanel>

                                    <!-- Active indicator bar -->
                                    <Border Grid.Column="0" Grid.ColumnSpan="2"
                                            HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                            Width="3" Background="{Binding ActiveBar}"
                                            CornerRadius="0,2,2,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Bottom info -->
                <Border DockPanel.Dock="Bottom" Padding="14,12" Background="#080A14"
                        BorderBrush="#232850" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <!-- Language selector -->
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Limba / Language" FontSize="9" Foreground="{StaticResource GrayBrush}"
                                       Margin="0,0,0,3"/>
                            <ComboBox x:Name="LanguageSelector" FontSize="10" Background="#13152A"
                                      Foreground="{StaticResource WhiteBrush}"
                                      BorderBrush="#232850" Padding="6,4"
                                      SelectionChanged="LanguageSelector_SelectionChanged">
                                <ComboBoxItem>Română (RO)</ComboBoxItem>
                                <ComboBoxItem>English (EN)</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="AdminLabel" Text="Administrator" FontSize="10"
                                       Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="SysInfoSidebar" FontSize="9"
                                   Foreground="{StaticResource GrayBrush}"
                                   Text="Se incarca informatii sistem..." TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- CONTENT AREA -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page container -->
            <Frame Grid.Row="0" x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BgBrush}"/>

            <!-- Navigation bar -->
            <Border Grid.Row="1" Background="#0D0F1E"
                    BorderBrush="#232850" BorderThickness="0,1,0,0"
                    Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnBack" Grid.Column="0"
                            Content="◀   Înapoi" Width="130" Height="38"
                            Style="{StaticResource GhostButton}"
                            Click="BtnBack_Click" Visibility="Collapsed"/>

                    <!-- Step dots -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ItemsControl x:Name="DotIndicators">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse Width="{Binding Size}" Height="{Binding Size}"
                                             Fill="{Binding Color}" Margin="4,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Button x:Name="BtnNext" Grid.Column="2"
                            Content="Continuă   ▶" Width="155" Height="38"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnNext_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
